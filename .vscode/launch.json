{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "VGR.Web (https)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/VGR.Web/bin/Debug/net10.0/VGR.Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/VGR.Web",
            "stopAtEntry": false,
            "console": "internalConsole",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:63399;http://localhost:63400"            }
        },
        {
            "name": "VGR.Web (http endast)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/VGR.Web/bin/Debug/net10.0/VGR.Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/VGR.Web",
            "stopAtEntry": false,
            "console": "internalConsole",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:63400"            }
        },
        {
            "name": ".NET Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}
